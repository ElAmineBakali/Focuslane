rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function createsOwnUserId() {
      return signedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    function keepsOwnUserId() {
      return signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    function ownsResource() {
      return signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /users/{uid} {
      allow read, create, update, delete: if isUser(uid);

      match /push_tokens/{tokenId} {
        allow read, create, update, delete: if isUser(uid);
      }

      match /ai_logs/{logId} {
        allow read: if isUser(uid);
        allow create, update, delete: if false;
      }

      match /notification_outbox/{docId} {
        allow read, create, update, delete: if isUser(uid);
      }

      match /pending_notifications/{docId} {
        allow read, create, update, delete: if isUser(uid);
      }

      match /{document=**} {
        allow read, create, update, delete: if isUser(uid);
      }
    }

    match /finance_transactions/{docId} {
      allow read, delete: if ownsResource();
      allow create: if createsOwnUserId();
      allow update: if keepsOwnUserId();
    }

    match /finance_subscriptions/{docId} {
      allow read, delete: if ownsResource();
      allow create: if createsOwnUserId();
      allow update: if keepsOwnUserId();
    }

    match /finance_assets/{docId} {
      allow read, delete: if ownsResource();
      allow create: if createsOwnUserId();
      allow update: if keepsOwnUserId();
    }

    match /finance_loans/{docId} {
      allow read, delete: if ownsResource();
      allow create: if createsOwnUserId();
      allow update: if keepsOwnUserId();
    }

    match /finance_debt_persons/{docId} {
      allow read, delete: if ownsResource();
      allow create: if createsOwnUserId();
      allow update: if keepsOwnUserId();
    }

    match /finance_debt_entries/{docId} {
      allow read, delete: if ownsResource();
      allow create: if createsOwnUserId();
      allow update: if keepsOwnUserId();
    }

    match /finance_deposit_accounts/{docId} {
      allow read, delete: if ownsResource();
      allow create: if createsOwnUserId();
      allow update: if keepsOwnUserId();
    }

    match /finance_deposit_movements/{docId} {
      allow read, delete: if ownsResource();
      allow create: if createsOwnUserId();
      allow update: if keepsOwnUserId();
    }

    match /finance_variable_expenses/{docId} {
      allow read, delete: if ownsResource();
      allow create: if createsOwnUserId();
      allow update: if keepsOwnUserId();
    }

    match /weekPlanners/{docId} {
      allow read, create, update, delete: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
